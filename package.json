{
  "name": "agentvisa-arbitrum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format:check": "prettier --check \"**/*.{json,yaml,yml,ts,mts}\"",
    "format:write": "prettier --write \"**/*.{json,yaml,yml,ts,mts}\"",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @agentvisa/contracts test:integration",
    "audit": "pnpm audit --audit-level high",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.15.30",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "4.18.0",
      "circom_tester>snarkjs": "0.7.6",
      "underscore": "1.13.8",
      "undici": "6.27.0",
      "ws": "8.21.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
