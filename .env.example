# Synthetic Arbitrum Sepolia credentials only.
# Never put production keys, mainnet keys, or real-value assets here.
# Copy to the workspace root as `.env` (gitignored).

ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_SYNTHETIC_DEPLOYER_KEY
ARBITRUM_SEPOLIA_AUTHORIZER_PRIVATE_KEY=0xREPLACE_WITH_SYNTHETIC_AUTHORIZER_KEY

