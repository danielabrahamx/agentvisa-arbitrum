{
  "name": "@agentvisa/localhost-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-static.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run test/static-build.test.ts",
    "start": "node scripts/serve-static.mjs",
    "start:public": "node scripts/serve-static.mjs"
  },
  "dependencies": {
    "@agentvisa/application-service": "workspace:*",
    "@agentvisa/browser-identity": "workspace:*",
    "@agentvisa/credential-issuer": "workspace:*",
    "@agentvisa/policy": "workspace:*",
    "@semaphore-protocol/group": "4.14.2",
    "viem": "2.54.2"
  },
  "devDependencies": {
    "@zk-kit/semaphore-artifacts": "4.13.0",
    "esbuild": "0.28.1"
  }
}
